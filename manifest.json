{
  "manifest_version": 3,
  "name": "Free FreePik",
  "version": "3.0",
  "description": "Unlock high-quality image downloads on Freepik with ease. Choose your preferred resolution and download directly from the page.",
  "permissions": ["downloads", "scripting"],
  "host_permissions": ["*://*.freepik.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "16": "icons/icon16.png",
    "24": "icons/icon24.png",
    "32": "icons/icon32.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.freepik.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
